# ============================================================
# AI Agent — Git 忽略规则
# ============================================================

# ── 环境变量（含 API Key，绝对不能提交）──
.env
.envrc

# ── Python 字节码 ──
__pycache__/
*.py[codz]
*$py.class

# ── 分发 / 打包 ──
build/
develop-eggs/
dist/
eggs/
.eggs/
*.egg-info/
.installed.cfg
*.egg

# ── 虚拟环境 ──
.venv/
venv/
env/
ENV/

# ── 向量数据库（体积大，运行时生成）──
data/chroma_db/
data/knowledge/chroma_db/

# ── 持久化数据（运行时生成）──
data/long_term_memory/
data/agent_logs/

# ── 日志 / 报告 ──
*.log
server.log

# ── 测试 / 覆盖率 ──
htmlcov/
.coverage
.coverage.*
.pytest_cache/
cover/

# ── IDE ──
.vscode/
.idea/
.spyderproject
.spyproject

# ── OS ──
Thumbs.db
.DS_Store

# ── 临时文件 ──
*.tmp
checkpoint_results.json

# ── Docker ──
.dockerignore
