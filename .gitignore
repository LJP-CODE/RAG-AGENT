# ============================================================
# AI Agent — Git 忽略规则
# ============================================================

# ── 环境变量（含 API Key，绝对不能提交）──
.env

# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# ── 虚拟环境 ──
.venv/
venv/

# ── 向量数据库（体积大，运行时生成）──
data/chroma_db/
data/knowledge/chroma_db/

# ── 持久化数据（运行时生成）──
data/long_term_memory/
data/agent_logs/

# ── 日志 / 报告 ──
*.log
server.log

# ── IDE ──
.vscode/
.idea/

# ── OS ──
Thumbs.db
.DS_Store

# ── Docker ──
.dockerignore

# ── 临时文件 ──
*.tmp
checkpoint_results.json
