# ============================================================
# AI Agent — 环境变量模板
# 复制为 .env 并填入真实值
# 警告：.env 文件已在 .gitignore 中，不会被提交到 Git
# ============================================================

# ── DeepSeek API Key（必填）──
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=你的DeepSeek密钥

# ── 可选：LLM API 地址（私有化部署时使用）──
# DEEPSEEK_API_BASE=https://api.deepseek.com

# ── 可选：配置文件路径（默认 config.yaml）──
# CONFIG_PATH=config.yaml

# ── NewsAPI Key — 新闻搜索 ──
# 从 https://newsapi.org/register 获取（免费版 100 次/天）
NEWS_API_KEY=你的NewsAPI密钥

# ── Bing Web Search Key — 网络搜索 ──
# 从 https://portal.azure.com → 创建 Bing Search 资源获取
# 国内可直连，免费版 1000 次/月
BING_API_KEY=你的Bing搜索密钥

# ── NewsAPI Key — 新闻搜索 ──
# 从 https://newsapi.org/register 获取（免费版 100 次/天）
NEWS_API_KEY=你的NewsAPI密钥

# ── 和风天气 Key — 天气查询 ──
# 从 https://dev.qweather.com 获取（免费版 10 次/分钟）
WEATHER_API_KEY=你的和风天气密钥

# ── API 认证 Key（逗号分隔白名单）──
# 不设置则开放模式，设置后 /ask 和 /ask/stream 需要 X-API-Key 请求头
# API_KEYS=sk-key1,sk-key2
